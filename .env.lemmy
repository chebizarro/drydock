# Drydock — Lemmy deployment config (192.168.40.110)
# Copy to .env before running: cp .env.lemmy .env
#
# ⚠️  WARNING: Never commit secrets to this file.
#     Use environment variables or a secrets manager for:
#     - DRYDOCK_SIGNER_BUNKER_URL
#     - DRYDOCK_SIGNER_NSEC
#     - DRYDOCK_LLM_API_KEY

DRYDOCK_DATABASE_URL=file:/data/drydock.db?_pragma=foreign_keys(1)&_pragma=busy_timeout(5000)
DRYDOCK_REPO_CACHE_DIR=/data/repos
DRYDOCK_RELAYS=wss://relay.sharegap.net,wss://nos.lol
DRYDOCK_LOG_LEVEL=info

# Lemmy's llama-server (Llama-3.3-70B-Instruct-Q4_K_M, ctx 16384)
# All model routes point here until Qwen Coder models are loaded on a separate port
DRYDOCK_PLANNER_BASE_URL=http://192.168.40.110:8080/v1
DRYDOCK_PLANNER_MODEL=llama-3.3-70b-instruct-q4_k_m
DRYDOCK_CODER32B_BASE_URL=http://192.168.40.110:8080/v1
DRYDOCK_CODER32B_MODEL=llama-3.3-70b-instruct-q4_k_m
DRYDOCK_LLM70B_BASE_URL=http://192.168.40.110:8080/v1
DRYDOCK_LLM70B_MODEL=llama-3.3-70b-instruct-q4_k_m
DRYDOCK_CODER14B_BASE_URL=http://192.168.40.110:8080/v1
DRYDOCK_CODER14B_MODEL=llama-3.3-70b-instruct-q4_k_m
DRYDOCK_META_BASE_URL=http://192.168.40.110:8080/v1
DRYDOCK_META_MODEL=llama-3.3-70b-instruct-q4_k_m
DRYDOCK_LLM_API_KEY=

# NIP-46 bunker — fill in when Signet is ready
# Format: bunker://<pubkey>?relay=wss://relay.sharegap.net&secret=<secret>
DRYDOCK_SIGNER_BUNKER_URL=

# Signing key — set via environment variable, NEVER commit here
# DRYDOCK_SIGNER_NSEC=
