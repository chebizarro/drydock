# Drydock — sanitized deployment example
# Copy to .env, replace every example.invalid host, and source credentials from
# your deployment secret manager. Never commit populated credentials.
# Production mode requires TLS for all service endpoints and authenticated LLM,
# Qdrant, and embedding endpoints.

DRYDOCK_ENV=production
DRYDOCK_DATABASE_URL=file:/data/drydock.db?_pragma=foreign_keys(1)&_pragma=busy_timeout(5000)
DRYDOCK_REPO_CACHE_DIR=/data/repos
DRYDOCK_RELAYS=wss://relay.example.invalid
DRYDOCK_LOG_LEVEL=info

# OpenAI-compatible model endpoints
DRYDOCK_PLANNER_BASE_URL=https://llm.example.invalid/v1
DRYDOCK_PLANNER_MODEL=replace-with-planner-model
DRYDOCK_CODER32B_BASE_URL=https://llm.example.invalid/v1
DRYDOCK_CODER32B_MODEL=replace-with-coder-32b-model
DRYDOCK_LLM70B_BASE_URL=https://llm.example.invalid/v1
DRYDOCK_LLM70B_MODEL=replace-with-70b-model
DRYDOCK_CODER14B_BASE_URL=https://llm.example.invalid/v1
DRYDOCK_CODER14B_MODEL=replace-with-coder-14b-model
DRYDOCK_META_BASE_URL=https://llm.example.invalid/v1
DRYDOCK_META_MODEL=replace-with-meta-model
DRYDOCK_LLM_API_KEY=replace-with-secret-manager-value

# Authenticated vector and embedding endpoints
DRYDOCK_QDRANT_URL=https://qdrant.example.invalid
DRYDOCK_QDRANT_API_KEY=replace-with-secret-manager-value
DRYDOCK_EMBED_BASE_URL=https://embed.example.invalid/v1
DRYDOCK_EMBED_MODEL=replace-with-embedding-model
DRYDOCK_EMBED_API_KEY=replace-with-secret-manager-value

# NIP-46 signer; replace the entire value with a real bunker connection string.
DRYDOCK_SIGNER_BUNKER_URL=bunker://replace-with-pubkey?relay=wss://relay.example.invalid&secret=replace-with-secret
