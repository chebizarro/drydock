# Runtime mode: listener | eval
DRYDOCK_MODE=listener

# Persistence
DRYDOCK_DATABASE_URL=file:/data/drydock.db?_pragma=foreign_keys(1)&_pragma=busy_timeout(5000)
DRYDOCK_REPO_CACHE_DIR=/data/repos
DRYDOCK_REPO_CACHE_MAX_COUNT=50
DRYDOCK_REPO_CACHE_MAX_SIZE_MB=10240
DRYDOCK_EVAL_DATASET_PATH=/app/eval/heldout-sample.json

# Nostr
DRYDOCK_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
DRYDOCK_SIGNER_BUNKER_URL=

# Logging
DRYDOCK_LOG_LEVEL=info

# OpenAI-compatible local endpoints/models
DRYDOCK_LLM_API_KEY=
DRYDOCK_PLANNER_BASE_URL=http://host.docker.internal:11434/v1
DRYDOCK_PLANNER_MODEL=qwen2.5-coder-14b-instruct-q4_k_m
DRYDOCK_CODER32B_BASE_URL=http://host.docker.internal:11434/v1
DRYDOCK_CODER32B_MODEL=qwen2.5-coder-32b-instruct-q4_k_m
DRYDOCK_LLM70B_BASE_URL=http://host.docker.internal:11435/v1
DRYDOCK_LLM70B_MODEL=llama-3.3-70b-instruct-q4_k_m
DRYDOCK_CODER14B_BASE_URL=http://host.docker.internal:11434/v1
DRYDOCK_CODER14B_MODEL=qwen2.5-coder-14b-instruct-q4_k_m
DRYDOCK_META_BASE_URL=http://host.docker.internal:11436/v1
DRYDOCK_META_MODEL=llama-3.3-70b-instruct-q4_k_m

# Qdrant vector store (optional — empty disables RAG features)
DRYDOCK_QDRANT_URL=
DRYDOCK_QDRANT_API_KEY=

# Embedding model (optional — required if Qdrant is enabled)
DRYDOCK_EMBED_BASE_URL=
DRYDOCK_EMBED_MODEL=nomic-embed-text
DRYDOCK_EMBED_API_KEY=

